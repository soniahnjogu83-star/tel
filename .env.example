# .env.example

# Daraja M-PESA integration environment variables

# Your Application ID.
MPESA_APP_ID=YOUR_APP_ID_HERE

# Your Application Secret.
MPESA_APP_SECRET=YOUR_APP_SECRET_HERE

# The environment (sandbox/production).
MPESA_ENVIRONMENT=sandbox

# The phone number in the format 2547XXXXXXXX
MPESA_PHONE_NUMBER=YOUR_PHONE_NUMBER_HERE

# The Shortcode of your M-PESA business account.
MPESA_SHORTCODE=YOUR_SHORTCODE_HERE

# The Lipa Na M-PESA Online Shortcode
MPESA_LIPA_SHORTCODE=YOUR_LIPA_SHORTCODE_HERE

# The M-PESA Passkey
MPESA_PASSKEY=YOUR_PASSKEY_HERE
